# ===========================================
# Client Environment Variables (public)
# ===========================================
# These variables are exposed to the browser (NEXT_PUBLIC_ prefix)

NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-01-14
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# ===========================================
# Server Environment Variables (secret)
# ===========================================
# These variables are only available on the server

# Cloudinary API credentials (for uploads)
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Sanity Webhook Secret (for cache revalidation)
# Configure in Sanity Dashboard: sanity.io/manage
SANITY_WEBHOOK_SECRET=

# Sanity API Tokens (for authenticated operations)
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=

# Sanity API overrides (optional, uses NEXT_PUBLIC_ values by default)
SANITY_API_PROJECT_ID=
SANITY_API_DATASET=

# ===========================================
# Standalone Sanity Studio (Vite)
# ===========================================
# Only needed when running `bunx sanity dev` outside Next.js

SANITY_STUDIO_PROJECT_ID=your-project-id
SANITY_STUDIO_DATASET=production
SANITY_STUDIO_API_VERSION=2026-01-14

# ===========================================
# Build/CI Options
# ===========================================
# Set to "1" to skip env validation during Docker/CI builds
# SKIP_ENV_VALIDATION=1
